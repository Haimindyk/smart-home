# Supabase project (Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Web Push (generate with `pnpm dlx web-push generate-vapid-keys`).
# Only the public key belongs on the client — the private key is an Edge
# Function secret (`supabase secrets set VAPID_PRIVATE_KEY=...`), never here.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
